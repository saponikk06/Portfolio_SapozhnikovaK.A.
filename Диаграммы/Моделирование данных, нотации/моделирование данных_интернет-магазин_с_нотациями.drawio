          <mxGeometry y="480" width="870" height="90" as="geometry" />
        </mxCell>
        <mxCell id="5O325MqEOkg0hkSNaYNA-183" value="Расширения" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;fillColor=#f5f5f5;top=0;left=0;bottom=1;right=1;overflow=hidden;fontSize=16;fontColor=#333333;strokeColor=#666666;perimeterSpacing=1;align=left;fontStyle=1;verticalAlign=top;" parent="5O325MqEOkg0hkSNaYNA-182" vertex="1">
          <mxGeometry width="290" height="90" as="geometry">
